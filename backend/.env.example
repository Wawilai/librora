# Librora backend
# Copy to backend/.env for local Docker/dev. Never commit real secrets.

# App
NODE_ENV=development
API_PORT=3001
WEB_BASE_URL=http://localhost:4173

# Database
# Runtime uses the pooled URL. Supabase usually uses port 6543.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=30&connect_timeout=10

# Prisma migrations use the direct URL. Supabase usually uses port 5432.
# Needed for CREATE EXTENSION vector and pgvector indexes.
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres

# Queue
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-generate-a-long-random-secret
JWT_REFRESH_SECRET=change-me-generate-another-long-random-secret

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# Worker
WORKER_CONCURRENCY=3
FETCH_TIMEOUT_MS=15000
FETCH_MAX_RESPONSE_BYTES=5242880

# Semantic search
SEMANTIC_MIN_SCORE=0.2
SEMANTIC_MAX_LIMIT=50

# Email
RESEND_API_KEY=
EMAIL_FROM=noreply@librora.xyz

# Billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID_MONTHLY=
STRIPE_PREMIUM_PRICE_ID_YEARLY=

# Anti-bot
TURNSTILE_SECRET_KEY=

# Browser extension
EXTENSION_ORIGIN=
