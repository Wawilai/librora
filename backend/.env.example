# Librora — Root Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
WEB_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3001
API_PORT=3001

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use "Transaction Pooler" URL (port 6543) at runtime.
# Use "Direct connection" URL (port 5432) for Prisma migrations (DATABASE_URL_DIRECT).
#
# api and worker each get their OWN pooled URL (DATABASE_URL_API /
# DATABASE_URL_WORKER) so each app's connection budget is sized to its own
# concurrency independently — this matters on Supabase Free tier, where the
# pgbouncer pool's total capacity is shared and tight. connection_limit=5 on
# each is enough headroom above the worker's job concurrency (default 3,
# WORKER_CONCURRENCY) without over-requesting from the shared pool.
# pool_timeout lets a request queue politely for a free connection during a
# pooler cold-start stall instead of hard-failing after Prisma's 10s default;
# connect_timeout bounds how long to wait on a genuinely dead pooler.
DATABASE_URL_API=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=30&connect_timeout=10
DATABASE_URL_WORKER=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=30&connect_timeout=10
# Fallback used by prisma CLI (migrate/studio) and any script that doesn't
# know about the api/worker split above.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&pool_timeout=30&connect_timeout=10
DATABASE_URL_DIRECT=postgresql://postgres.[project-ref]:[password]@aws-0-[region].supabase.com:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
# dev:  redis://localhost:6379  (Docker Compose)
# prod: rediss://:[token]@[endpoint].upstash.io:6379  (Upstash)
REDIS_URL=redis://localhost:6379

# ── Qdrant ───────────────────────────────────────────────────────────────────
# dev:  http://localhost:6333  (Docker Compose)
# prod: https://[cluster-id].[region].aws.cloud.qdrant.io  (Qdrant Cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=librora_items

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-generate-with-openssl-rand-base64-48
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=change-me-different-secret-from-access
JWT_REFRESH_TTL=2592000

# ── AI (OpenAI) ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=3
WORKER_MAX_ATTEMPTS=3
FETCH_TIMEOUT_MS=15000
FETCH_MAX_RESPONSE_BYTES=5242880

# ── Search ───────────────────────────────────────────────────────────────────
SEMANTIC_MIN_SCORE=0.7
SEMANTIC_DEFAULT_LIMIT=10
SEMANTIC_MAX_LIMIT=50

# ── Account deletion ─────────────────────────────────────────────────────────
# Days between a user requesting deletion (soft-delete) and the daily purge job
# permanently removing their data.
ACCOUNT_DELETION_GRACE_DAYS=30

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys — requires a verified sending domain.
RESEND_API_KEY=
EMAIL_FROM=noreply@librora.app
PASSWORD_RESET_TOKEN_TTL=1800
EMAIL_VERIFICATION_TOKEN_TTL=86400

# ── Billing (Stripe) ─────────────────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API keys / Webhooks
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (Stripe Dashboard → Product catalog → your Premium product →
# Pricing section) — must start with "price_", NOT "prod_" (that's the
# Product ID, a common mix-up that makes checkout-session return 500).
STRIPE_PREMIUM_PRICE_ID_MONTHLY=
STRIPE_PREMIUM_PRICE_ID_YEARLY=

# ── Anti-bot (Cloudflare Turnstile) ──────────────────────────────────────────
# Get from: Cloudflare Dashboard → Turnstile — free tier available.
# Left blank, registration skips CAPTCHA verification (dev-friendly default).
TURNSTILE_SECRET_KEY=

# ── Library Clipper extension ─────────────────────────────────────────────────
# chrome-extension://<extension-id> — find the ID at chrome://extensions (dev,
# with Developer mode on) or the Chrome Web Store listing once published.
EXTENSION_ORIGIN=
